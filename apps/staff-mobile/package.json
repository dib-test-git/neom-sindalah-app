{
  "name": "staff-mobile",
  "version": "0.3.0",
  "private": true,
  "description": "Sindalah staff ops mobile app (React Native, TypeScript)",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build:ios:debug": "xcodebuild -workspace ios/SindalahStaff.xcworkspace -scheme SindalahStaff -configuration Debug -sdk iphonesimulator"
  },
  "dependencies": {
    "@apollo/client": "^3.10.0",
    "@react-native-async-storage/async-storage": "^1.23.0",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "graphql": "^16.8.1",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-gesture-handler": "^2.16.0",
    "react-native-reanimated": "^3.10.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-screens": "^3.31.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.79",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "typescript": "^5.4.5"
  }
}
